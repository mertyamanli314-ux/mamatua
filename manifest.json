{
  "manifest_version": 3,
  "name": "Matrix",
  "version": "1.0",
  "description": "Take over starve.io",
  "permissions": [
    "scripting",
    "activeTab",
    "storage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "icons": {
    "16": "images/matrix.png",
    "48": "images/matrix.png",
    "128": "images/matrix.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.min.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content.min.js",
        "bundle.min.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}